---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { contacts } from '../../data/contact'
import { getLangFromUrl, useTranslations } from '../../utils'
import LangSelector from './LangSelector.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const reservaUrl = getRelativeLocaleUrl(lang, 'reserva')
const tallersUrl = getRelativeLocaleUrl(lang, 'tallers')
const bioUrl = '#bio'
const contactUrl = '#contact'
const termsUrl = getRelativeLocaleUrl(lang, 'condicions')
const privacyUrl = getRelativeLocaleUrl(lang, 'privacitat')
---

<footer class="page-padding mx-auto bg-dark text-soft">
  <nav class="py-8 flex justify-between items-center">
    <ul>
      <li>
        <a href={reservaUrl}>{t('footer.a.reserva')}</a>
      </li>
      <li>
        <a href={tallersUrl}>{t('footer.a.tallers')}</a>
      </li>
      <li>
        <a href={bioUrl}>{t('footer.a.bio')}</a>
      </li>
      <li>
        <a href={contactUrl}>{t('footer.a.contact')}</a>
      </li>
    </ul>
    <ul class="text-center">
      <li>
        <a href={termsUrl}>{t('footer.a.terms')}</a>
      </li>
      <li>
        <a href={privacyUrl}>{t('footer.a.privacy')}</a>
      </li>
    </ul>
    <LangSelector />
  </nav>
</footer>
<hr class="text-soft" />
<p class="page-padding bg-dark text-soft text-xs py-4">
  <b class="textxl me-2">♧</b>
  {t('footer.author')}
  <a class="underline" href={contacts.webAuthorUrl}> @aymyo</a>
  {t('footer.place.year')}
  ~ Barcelona, 2024
</p>

<style>
  li {
    margin: 0.5rem 0;
  }
  a:hover {
    text-decoration: underline;
  }
</style>

---
import { constants } from '../../config'
import { tallers } from '../../content'
---

<section id="contact" class="page-padding md:max-w-[100ch] mx-auto my-20">
  <div class="my-12 flex gap-8 flex-wrap justify-between items-center">
    <div class="lg:max-w-[50%]">
      <h3 class="text-4xl md:text-5xl font-[500]">tallerets a mida</h3>
      <p class="text-xl my-6">
        Tens una idea de talleret que vols fer amb els teus amics per un event o
        perque si, o bé no et cuadren les dates? Proposa’m la teva idea i podem
        fer un talleret a mida a partir de 4 persones.
      </p>
      <address class="flex items-center gap-6">
        <a
          class="c-button flex items-center gap-3"
          href=`mailto:${constants.email}`
        >
          <span class="text-xl">
            <b class="text-2xl me-1">✎</b>
            {constants.email}
          </span>
        </a>
      </address>
    </div>

    <img
      width="256"
      height="216"
      class="text-dark w-64 object-cover rounded-sm"
      src="/icons/mida.svg"
      alt={tallers.aMida.imgAlt}
    />
  </div>
</section>

---
import { contacts } from '../../data/contact'
import { getLangFromUrl, useTranslations } from '../../utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section id="contact" class="page-padding md:max-w-[100ch] mx-auto my-20">
  <div class="my-12 flex gap-8 flex-wrap justify-between items-center">
    <div class="lg:max-w-[50%]">
      <h3 class="text-4xl md:text-5xl font-[500]">{t('amida.title')}</h3>
      <p class="text-xl my-6">
        {t('amida.text')}
      </p>
      <address class="flex items-center gap-6">
        <a
          class="c-button flex items-center gap-3"
          href=`mailto:${contacts.email}`
        >
          <span class="text-xl">
            <b class="text-2xl me-1">✎</b>
            {contacts.email}
          </span>
        </a>
      </address>
    </div>

    <img
      width="256"
      height="216"
      class="text-dark w-64 object-cover rounded-sm"
      src="/icons/mida.svg"
      alt=""
    />
  </div>
</section>

---
import { constants } from '../../config'
---

<section class="page-padding flex items-center flex-wrap gap-6 py-6">
  <h3 class="text-3xl me-auto">
    per més informació, segueix-me a instagram o envia'm un correu!
  </h3>

  <div class="text-xl flex gap-6 items-center justify-around flex-wrap-reverse">
    <img
      width="112"
      height="75"
      class="w-28 text-sm text-center"
      src="icons/carta.svg"
      alt="il·lustració de una carteta amb un cor al mitg"
    />
    <div class="italic text-base md:text-xl">
      <p class="py-2">
        instagram — <a
          class="underline p-2"
          href={`https://www.instagram.com/${constants.instagramId}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          @{constants.instagramId}
        </a>
      </p>
      <p class="py-2">
        email — <a class="underline p-2" href={`mailto:${constants.email}`}>
          {constants.email}
        </a>
      </p>
    </div>
  </div>
</section>

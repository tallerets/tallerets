---
import { getLangFromUrl, useTranslations } from '../../utils'
import Header from './Header.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const nextUrl = '#tallers'
---

<section class="relative h-screen overflow-hidden">
  <div class="container">
    <video autoplay loop muted playsinline class="video absolute z-1">
      <source src="/vids/hero.mp4" type="video/mp4" />
    </video>
  </div>
  <Header className="text-dark absolute" />
  <div
    class="relative page-padding h-[100vh] bg-black flex flex-col items-start pb-8"
  >
    <h1
      class="text-dark text-8xl sm:text-8xl lg:text-[10rem] mt-auto pt-20 mb-6 font-[400]"
    >
      {t('hero.h1-1')}<br />
      {t('hero.h1-2')}
    </h1>

    <div class="flex justify-end items-center w-full gap-4">
      <a
        href={nextUrl}
        class="block border-2 px-4 py-3 rounded-full text-2xl font-bold hover:-rotate-6 transition-transform my-8 bg-soft me-auto text-nowrap"
      >
        {t('hero.cta')}
      </a>
    </div>
  </div>
</section>

<style>
  .container {
    height: auto;
    width: 100vw;
    position: relative;
  }

  .video {
    filter: contrast(1.4) opacity(0.7) blur(2.6px);
    min-width: 100vw;
    object-fit: cover;
    object-position: center;
    height: 100vh;
  }
</style>

---
import { getLangFromUrl, useTranslations } from '../../utils'

interface Props {
  className: string
  isMobile?: boolean
}

const { className, isMobile } = Astro.props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<ul class={className}>
  <li>
    <a href="/reserva">{t('nav.a.reserva')}</a>
  </li>
  <li>
    <a href="/tallers">{t('nav.a.tallers')}</a>
  </li>
  <li>
    <a href="/#bio" target={isMobile ? '_blank' : ''}>{t('nav.a.bio')}</a>
  </li>
  <li>
    <a href="/#contact" target={isMobile ? '_blank' : ''}
      >{t('nav.a.contact')}</a
    >
  </li>
</ul>

<style>
  a {
    @apply block border bg-soft rounded-full text-center px-5 pb-[0.4rem] pt-[0.4rem] hover:-rotate-6 hover:border-red hover:text-red transition-transform;
  }
</style>

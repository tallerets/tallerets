---
import { constants } from '../../config'
---

<div class="flex flex-col items-center justify-center text-center h-[90vh] p-4">
  <span class="text-7xl">🚧</span>
  <h1 class="text-4xl mt-8">Estem fent obres a la web!</h1>
  <h2 class="text-xl mt-8 max-w-[40ch]">
    Si tens qualsevol dubte o vols informació sobre els tallers, pots seguir-me
    a{' '}
    <a
      class="underline"
      href={`https://www.instagram.com/${constants.instagramId}`}
      target="_blank"
      rel="noopener noreferrer"
    >
      @{constants.instagramId}
    </a>
    o escriure'm a{' '}
    <a class="underline" href={`mailto:${constants.email}`}>
      {constants.email}
    </a>
  </h2>
</div>

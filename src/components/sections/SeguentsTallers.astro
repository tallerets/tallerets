---
import { events, tallers } from '../../content'
import TallerPostcard from '../TallerPostcard.astro'

const nextTallerets = tallers.slice(0, 2)
---

<section id="tallerets" class="page-padding py-24">
  <h3 class="text-4xl md:text-5xl md:text-center">següents tallerets</h3>

  <div
    class="flex flex-col gap-8 md:flex-row md:justify-center my-24 flex-wrap"
  >
    {
      nextTallerets.map((taller) => {
        const event = events.find((e) => e.tallerId === taller.id)

        return (
          <TallerPostcard
            title={taller.title}
            desc={taller.desc}
            imgSrc={taller.imgSrc}
            imgAlt={taller.imgAlt}
            data={event?.date ?? 'Pendent de programar'}
            href={`/reserva#${event?.tallerId}${event?.date}`}
          />
        )
      })
    }
  </div>

  <div class="flex justify-center gap-6 flex-wrap">
    <a class="c-button" href="/tallers">tots els tallers!</a>
    <a class="c-button" href="/reserva">calendari i reserves</a>
  </div>
</section>

---
import { formattedEventArray } from '../../content'
import { getNextTallerets, dateToString } from '../../utils'
import TallerPostcard from '../TallerPostcard.astro'

const nextTallerets = getNextTallerets()
---

<section id="tallerets" class="page-padding py-24">
  <h3 class="text-4xl md:text-5xl md:text-center">pròxims tallerets</h3>

  <ul class="flex flex-col gap-8 md:flex-row md:justify-center my-24 flex-wrap">
    {
      nextTallerets.length !== 0 &&
        nextTallerets.map((taller) => {
          const relatedEvent = formattedEventArray.find(
            (e) => e.tallerId === taller.id,
          )
          const dateString = dateToString(relatedEvent?.date ?? 'Properament')

          return (
            <TallerPostcard
              id={taller.id}
              title={taller.title}
              desc={taller.desc}
              imgSrc={taller.imgSrc}
              imgAlt={taller.imgAlt}
              data={dateString}
              href={`/reserva#${relatedEvent?.tallerId}${dateString}`}
            />
          )
        })
    }
    {
      nextTallerets.length === 0 && (
        <p class="text-center italic">
          Més tallers properament! Consulta la llista completa i contacta'm si
          voldries organitzar-ne un.
        </p>
      )
    }
  </ul>

  <div class="flex justify-center gap-6 flex-wrap">
    <a class="c-button" href="/tallers">tots els tallers</a>
    <a class="c-button" href="/reserva">calendari i reserves</a>
  </div>
</section>

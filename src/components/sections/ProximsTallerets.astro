---
import { formattedEventArray, tallers } from '../../content'
import TallerPostcard from '../TallerPostcard.astro'

const nextAvailableTallers = formattedEventArray
  .filter((e) => e.availability !== 'none')
  .filter((e) => new Date(e.date) > new Date())
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .splice(0, 2)
  .map((e) => ({
    id: e.tallerId,
    ...tallers[e.tallerId],
  }))
---

<section id="tallerets" class="page-padding py-24">
  <h3 class="text-4xl md:text-5xl md:text-center">pròxims tallerets</h3>

  <div
    class="flex flex-col gap-8 md:flex-row md:justify-center my-24 flex-wrap"
  >
    {
      nextAvailableTallers.map((taller) => {
        const relatedEvent = formattedEventArray.find(
          (e) => e.tallerId === taller.id,
        )
        const dateString =
          relatedEvent?.date.toLocaleString('ca-ES', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          }) ?? 'Properament'
        return (
          <>
            <TallerPostcard
              id={taller.id}
              title={taller.title}
              desc={taller.desc}
              imgSrc={taller.imgSrc}
              imgAlt={taller.imgAlt}
              data={dateString}
              href={`/reserva#${relatedEvent?.tallerId}${dateString}`}
            />
          </>
        )
      })
    }
  </div>

  <div class="flex justify-center gap-6 flex-wrap">
    <a class="c-button" href="/tallers">tots els tallers!</a>
    <a class="c-button" href="/reserva">calendari i reserves</a>
  </div>
</section>

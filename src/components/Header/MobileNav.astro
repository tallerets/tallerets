---
import NavLinks from './NavLinks.astro'

interface Props {
  className?: string
}
const { className } = Astro.props
---

<div class={className}>
  <input class="hidden" type="checkbox" id="nav-menu" />
  <label for="nav-menu" id="open-button" class="text-3xl cursor-pointer z-20">
    <img src="/icons/menu.svg" width="48" height="48" alt="Abrir menú" />
  </label>
  <label
    for="nav-menu"
    id="close-button"
    class="hidden text-3xl cursor-pointer z-20 top-6 right-5"
  >
    <img src="/icons/close.svg" width="48" height="48" alt="Cerrar menú" />
  </label>
  <nav id="overlay" class="c-menu bg-dark">
    <NavLinks
      className="text-4xl flex flex-col gap-12 text-nowrap font-[500]"
    />
  </nav>

  <style>
    input[type='checkbox']:checked ~ #overlay {
      display: flex;
    }
    input[type='checkbox']:checked ~ #close-button {
      position: fixed;
      display: block;
    }
    input[type='checkbox']:checked ~ #open-button {
      display: none;
    }
    .c-menu {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      gap: 3rem;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }
  </style>
</div>

---
import Footer from '../sections/Footer.astro'

import Layout from '../../layouts/BaseLayout.astro'
import Header from '../sections/Header.astro'

const { section } = Astro.props
const { Content } = await section.render()
const { title, desc, image, links } = section.data
---

<Layout title={title} description={desc}>
  <Header />
  <section class="page-padding mx-auto pt-8 pb-12 flex flex-col items-center">
    <h1
      class="text-4xl md:text-6xl text-center md:leading-tight font-[500] max-w-[20ch]"
    >
      {title}
      <span>
        <img
          width="48"
          height="48"
          class="w-12 inline text-sm"
          src="/icons/flor.svg"
          alt=""
        />
      </span>
    </h1>

    <div
      class="flex flex-wrap md:flex-nowrap gap-16 md:gap-28 items-center justify-center mt-16"
    >
      {
        image.url && (
          <img
            width="320"
            height="328"
            class="min-w-[320px] border-8 border-dark bg-dark rounded"
            src={image.url}
            alt={image.alt}
          />
        )
      }
      <div class="text-2xl md:text-3xl max-w-[20ch] content">
        <Content />
      </div>
    </div>

    <div class="pb-8 pt-16 flex items-center gap-4">
      {
        links.map((link: { url: string; text: string }) => (
          <a
            href={link.url}
            class="block border-2 px-4 py-3 rounded-full text-2xl font-bold hover:-rotate-6 transition-transform"
          >
            {link.text}
          </a>
        ))
      }
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .content > p {
    margin-bottom: 4rem;
  }
</style>

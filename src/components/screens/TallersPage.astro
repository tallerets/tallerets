---
import Layout from '../../layouts/Layout.astro'
import Footer from '../../components/sections/Footer.astro'
import Header from '../../components/sections/Header.astro'
import TallerPostcard from '../cards/TallerPostcard.astro'
import { getLangFromUrl, useTranslations } from '../../utils'
import { getCollection } from 'astro:content'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const reservaUrl = 'https://tallerets.setmore.com/tallerets'
const allTallers = await getCollection('mono', ({ id }) => {
  return id.startsWith(lang)
})
---

<Layout title={t('seo.tallers.title')} description={t('seo.tallers.desc')}>
  <Header className="bg-soft text-dark relative" />
  <main>
    <h1
      class="mt-2 text-4xl md:text-6xl text-center md:leading-tight font-[500]"
    >
      {t('tallers.title')}
      <span>
        <img
          width="48"
          height="48"
          class="w-12 inline text-sm"
          src="/icons/flor.svg"
          alt=""
        />
      </span>
    </h1>
    <section
      class="my-4 lg:my-12 flex md:justify-center flex-wrap gap-x-16 gap-y-4"
    >
      <aside class="page-padding">
        <div class="md:w-[40rem] xl:w-80 sticky top-12 pt-4">
          <h2 class="hidden md:block text-3xl mb-4 font-bold">
            Índex de tallers
          </h2>
          <ul class="mb-8 text-lg">
            {
              allTallers.map((taller) => {
                return (
                  <li class="mb-1 list-decimal ms-4">
                    <a href={`#${taller.id}`} class="hover:underline">
                      {taller.data.title}
                    </a>
                  </li>
                )
              })
            }
          </ul>
          <div class="flex">
            <a class="c-button" href={reservaUrl}>{t('tallers.a.reserva')}</a>
          </div>
        </div>
      </aside>
      <ul class="page-padding flex flex-col gap-10 pt-6 pb-12 overflow-hidden">
        {
          allTallers.map((taller) => {
            return <TallerPostcard taller={taller} />
          })
        }
      </ul>
    </section>
  </main>

  <hr />
  <Footer />
</Layout>

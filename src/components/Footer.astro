---
import { getCollection, getEntry } from 'astro:content'
import { getLangFromUrl, removeLangFromSlug, useTranslatedPath } from '../utils'
import LangSelector from './LangSelector.astro'

const lang = getLangFromUrl(Astro.url)
const translatePath = useTranslatedPath(lang)

const footerSection = await getEntry('sections', `${lang}/partial_footer`)
const footerLinks = footerSection?.data.links || []

const legalDocs = await getCollection('legal', ({ id }) => {
  return id.startsWith(lang)
})
---

<footer class="page-padding mx-auto bg-dark text-soft">
  <section class="flex justify-between gap-8 px-4 pt-16 pb-12 flex-wrap">
    <div class="flex flex-col justify-center">
      <img
        src="/icons/logo-s.png"
        alt="Tallerets"
        class="w-32"
        width="260"
        height="130"
      />
      <p class="mt-2">{footerSection?.data.title}</p>
      <p class="mt-2 opacity-60">
        {footerSection?.data.other.copyright}
      </p>
    </div>
    <div>
      <h5 class="font-bold opacity-60">
        {footerSection?.data.other.labels[0]}
      </h5>
      <ul>
        {
          footerLinks &&
            footerLinks.map((link) => (
              <li>
                <a href={link.url}>{link.text}</a>
              </li>
            ))
        }
      </ul>
    </div>
    <div>
      <h5 class="font-bold opacity-60">
        {footerSection?.data.other.labels[1]}
      </h5>
      <ul>
        {
          legalDocs.map(({ slug, data: { title } }) => {
            const correctedSlug =
              translatePath('/legal') + removeLangFromSlug(slug)
            return (
              <li>
                <a href={correctedSlug}>{title}</a>
              </li>
            )
          })
        }
      </ul>
    </div>
    <div>
      <h5 class="font-bold opacity-60">
        {footerSection?.data.other.labels[2]}
      </h5>
      <LangSelector />
    </div>
  </section>
</footer>
<p
  class="page-padding bg-dark text-soft text-xs pb-4 pt-4 text-center text-opacity-60"
>
  {footerSection?.data.other.authorTitle}
  <a
    target="_blank"
    class="underline"
    href={footerSection?.data.other.authorUrl}
  >
    {footerSection?.data.other.authorName}
  </a>
  ~ Barcelona, 2024
</p>

<style>
  li {
    margin: 0.5rem 0 0;
  }
</style>

---
const { title, desc, imgSrc, imgAlt } = Astro.props
---

<div class="border p-3 md:max-w-80">
  <p class="uppercase pb-3">{title}</p>
  <div class="w-100 bg-dark h-56 text-soft text-sm">
    <img
      class="w-full h-full object-cover border border-dark"
      src={imgSrc}
      alt={imgAlt}
    />
  </div>
  <div class="text-sm pt-3">
    {desc}
  </div>
</div>

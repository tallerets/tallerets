---
const { id, title, desc, imgSrc, imgAlt, data, href } = Astro.props

const cursorClass = href ? 'hover:cursor-pointer' : ''
---

<li class="odd:rotate-1 even:-rotate-1 hover:rotate-0 list-none">
  <a
    id={id}
    href={href}
    class={`${cursorClass} border bg-dark text-soft max-w-[40rem] min-h-[26rem] rounded-md flex flex-col sm:flex-row`}
  >
    <div class="p-8 flex flex-col">
      <p class="uppercase text-2xl">{title}</p>
      <div class="py-5 mb-auto">
        {desc}
      </div>
      {data && <p class="text-sm font-mono">Proper: {data}</p>}
    </div>
    <div
      class="min-w-[40%] h-[14rem] sm:h-[26rem] bg-dark text-soft rounded-b sm:rounded-e sm:rounded-bl-none"
    >
      <img
        class="pointer-events-none w-full h-full border-soft object-cover rounded-b border-t sm:rounded-e sm:rounded-bl-none sm:border-s sm:border-t-0"
        src={imgSrc}
        alt={imgAlt}
      />
    </div>
  </a>
</li>

<style>
  .postcard {
    transition:
      transform 0.3s,
      border-color 0.3s;
  }
</style>

---
import Layout from '../layouts/Layout.astro'
import Footer from '../components/sections/Footer.astro'
import Header from '../components/sections/Header.astro'
import { events, tallers, formattedEventArray } from '../content'
import EventCard from '../components/EventCard.astro'
import Contact from '../components/sections/Contact.astro'
import Reserves from '../components/sections/Reserves.astro'

const eventMonths = events.map((event) => {
  const { day, month, year } = event.date
  const date = new Date(Number(year), Number(month) - 1, Number(day))
  return date.getMonth()
})

const monthsWithWorkshops = Array.from(new Set(eventMonths))

const weekdays = [
  'Diumenge',
  'Dilluns',
  'Dimarts',
  'Dimecres',
  'Dijous',
  'Divendres',
  'Dissabte',
]
---

<Layout title="tallerets: calendari">
  <Header className="border-b bg-soft text-dark relative" />
  <main>
    <section
      class="my-4 lg:my-12 flex md:justify-center flex-wrap gap-x-16 gap-y-6"
    >
      <aside class="page-padding">
        <div class="md:w-[40rem] xl:w-80 sticky top-12 pt-4">
          <h1 class="text-2xl md:text-4xl mb-4">calendari</h1>
          <p>
            Aquí tens els pròxims tallerets que estic organitzant. Si no hi ha
            cap data que t’interessi, pots reservar un talleret a mida per a tu
            i els teus.
          </p>
          <div class="flex my-8">
            <a class="c-button" href="/tallers">llista de tallers</a>
          </div>
          <Reserves />
        </div>
      </aside>
      <div class="max-w-[60rem]">
        {
          monthsWithWorkshops.map((month) => {
            return (
              <>
                <h2 class="text-2xl md:text-4xl mb-4 text-center mt-8 underline">
                  {new Date(0, month).toLocaleString('ca-ES', {
                    month: 'long',
                  })}
                </h2>
                <ul class="page-padding flex flex-wrap gap-4 py-6 overflow-hidden justify-center">
                  {formattedEventArray
                    .filter((e) => e.date.getMonth() === month)
                    .map((event) => {
                      const dateString = `${
                        weekdays[event.date.getDay()]
                      } ${event.date.toLocaleDateString('ca-ES', {
                        day: 'numeric',
                      })}`

                      const id =
                        event.tallerId +
                        event.date.toLocaleString('ca-ES', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })

                      return (
                        <EventCard
                          id={id}
                          title={tallers[event.tallerId].title}
                          date={dateString}
                          time={event.time}
                          price={event.price}
                          slots={event.availability}
                          location={event.location}
                        />
                      )
                    })}
                </ul>
              </>
            )
          })
        }
      </div>
    </section>
  </main>

  <hr />
  <Contact />
  <Footer />
</Layout>

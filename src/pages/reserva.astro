---
import Layout from '../layouts/Layout.astro'
import { constants } from '../config'
import Footer from '../components/sections/Footer.astro'
import Header from '../components/sections/Header.astro'
import { events, tallers } from '../content'
import EventCard from '../components/EventCard.astro'
import Contact from '../components/sections/Contact.astro'
import Reserves from '../components/sections/Reserves.astro'
---

<Layout title="tallerets: calendari">
  <Header className="border-b bg-soft text-dark relative" />
  <main>
    <section
      class="my-4 lg:my-12 flex md:justify-center flex-wrap gap-x-16 gap-y-6"
    >
      <aside class="page-padding">
        <div class="md:w-[40rem] xl:w-80 sticky top-12 pt-4">
          <h2 class="text-xl md:text-2xl mb-4">calendari</h2>
          <p>
            Aquí tens els pròxims tallerets que estic organitzant. Si no hi ha
            cap data que t’interessi, pots reservar un talleret a mida per a tu
            i els teus.
          </p>
          <div class="flex my-8">
            <a class="c-button" href="/tallers">llista de tallers</a>
          </div>
          <Reserves />
        </div>
      </aside>
      <div class="max-w-[60rem]">
        <ul
          class="page-padding flex flex-wrap gap-4 py-6 overflow-hidden justify-center"
        >
          {
            events.map((event) => {
              return (
                <EventCard
                  id={event.tallerId + event.date}
                  title={event.title}
                  date={event.date}
                  time={event.time}
                  price={event.price}
                  slots={event.slots}
                  location={event.location}
                />
              )
            })
          }
        </ul>
      </div>
    </section>
  </main>

  <hr />
  <Contact />
  <Footer />
</Layout>

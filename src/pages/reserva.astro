---
import Layout from '../layouts/Layout.astro'
import Footer from '../components/sections/Footer.astro'
import Header from '../components/sections/Header.astro'
import { tallers, formattedEventArray, tallersArray } from '../content'
import EventCard from '../components/EventCard.astro'
import Contact from '../components/sections/Contact.astro'
import Reserves from '../components/sections/Reserves.astro'
import {
  createEventUniqueId,
  createMailToString,
  dateToWeekday,
  getMonthsWithEvents,
  getWrittenMonth,
} from '../utils'

const monthsWithEvents = getMonthsWithEvents()

const mailTo = createMailToString({
  title: '[TALLERET]',
  date: '[DIA]',
  time: '[HORA]',
  location: '[ESPAI]',
})
---

<Layout
  title="tallerets — calendari i reserves"
  description="Aquí pots trobar totes les dates del següents tallers creatius a Barcelona, entre setmana, per les tardes i els caps de setmana."
>
  <Header className="border-b bg-soft text-dark relative" />
  <main>
    <section
      class="my-4 lg:my-12 flex md:justify-center flex-wrap gap-x-16 gap-y-6"
    >
      <aside class="page-padding">
        <div class="md:w-[40rem] xl:w-80 sticky top-12 pt-4">
          <h1 class="text-2xl md:text-4xl mb-4">calendari</h1>
          <p>
            Aquí tens els pròxims tallerets que estic organitzant. Si no hi ha
            cap data que t’interessi, pots reservar un talleret a mida per a tu
            i els teus.
          </p>
          <div class="flex my-8">
            <a class="c-button" href="/tallers">llista de tallers</a>
          </div>
          <h2 class="text-xl md:text-3xl mb-4">com reservar?</h2>
          <div class="border rounded p-3">
            <Reserves mailto={mailTo} />
          </div>
        </div>
      </aside>

      <div class="max-w-[60rem]">
        {
          monthsWithEvents.map((month) => {
            return (
              <>
                <h2 class="text-2xl md:text-4xl mb-4 text-center mt-8">
                  {getWrittenMonth(month)}
                </h2>
                <ul class="page-padding flex flex-wrap gap-6 py-6 overflow-hidden justify-center">
                  {formattedEventArray
                    .filter((e) => e.date.getMonth() === month)
                    .map((e) => {
                      return (
                        <EventCard
                          id={createEventUniqueId(e)}
                          tallerId={e.tallerId}
                          title={tallers[e.tallerId]?.title}
                          date={dateToWeekday(e.date)}
                          time={e.time}
                          price={e.price + '€/pax'}
                          slots={e.availability}
                          location={e.location}
                        />
                      )
                    })}
                </ul>
              </>
            )
          })
        }

        <h2 class="text-2xl md:text-4xl mb-4 text-center mt-8">
          trobem la data adequada!
        </h2>
        <ul
          class="page-padding flex flex-wrap gap-6 py-6 overflow-hidden justify-center"
        >
          {
            tallersArray.map((taller) => {
              return (
                <EventCard
                  id={taller.id}
                  tallerId={taller.id}
                  title={taller.title}
                  date="Quan vulguis!"
                  location="Preu i localització a convenir. Entre 4 i 16 persones. Contacta'm!"
                />
              )
            })
          }
        </ul>
      </div>
    </section>
  </main>

  <hr />
  <Contact />
  <Footer />
</Layout>

<script>
  const getDialogByHash = () =>
    document.getElementById(
      decodeURI(window.location.hash).substring(1),
    ) as HTMLDialogElement

  getDialogByHash()?.showModal()

  window.addEventListener('popstate', () => {
    getDialogByHash()?.showModal()
  })
</script>

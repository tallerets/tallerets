---
import Layout from '../layouts/Layout.astro'
import Footer from '../components/sections/Footer.astro'
import Header from '../components/sections/Header.astro'
import { events, tallers, formattedEventArray } from '../content'
import EventCard from '../components/EventCard.astro'
import Contact from '../components/sections/Contact.astro'
import Reserves from '../components/sections/Reserves.astro'
import { constants } from '../config'

const eventMonths = events.map((event) => {
  const { day, month, year } = event.date
  const date = new Date(Number(year), Number(month) - 1, Number(day))
  return date.getMonth()
})

const monthsWithWorkshops = Array.from(new Set(eventMonths))

const weekdays = [
  'Diumenge',
  'Dilluns',
  'Dimarts',
  'Dimecres',
  'Dijous',
  'Divendres',
  'Dissabte',
]

const availabilityMap = {
  some: 'Places lliures',
  none: 'Complet',
  last: 'Ultimes places!',
}

const mailTo = `mailto:${constants.email}?subject=Reserva%20per%20talleret%20%5BTITOL%5D&body=Hola!%0D%0AM'agradaria%20fer%20una%20reserva%20a%20nom%20de%20%5BNOM%20I%20COGNOMS%5D%20per%20%5BNUMERO%20DE%20PLACES%5D%20places%20al%20talleret%20%5BTITOL%5D%20del%20dia%20%5BDIA%5D%20a%20les%20%5BHORA%5D%20a%20%5BESPAI%5D.%0D%0A%0D%0AGr%C3%A0cies!%0D%0A`
---

<Layout title="tallerets: calendari">
  <Header className="border-b bg-soft text-dark relative" />
  <main>
    <section
      class="my-4 lg:my-12 flex md:justify-center flex-wrap gap-x-16 gap-y-6"
    >
      <aside class="page-padding">
        <div class="md:w-[40rem] xl:w-80 sticky top-12 pt-4">
          <h1 class="text-2xl md:text-4xl mb-4">calendari</h1>
          <p>
            Aquí tens els pròxims tallerets que estic organitzant. Si no hi ha
            cap data que t’interessi, pots reservar un talleret a mida per a tu
            i els teus.
          </p>
          <div class="flex my-8">
            <a class="c-button" href="/tallers">llista de tallers</a>
          </div>
          <h2 class="text-xl md:text-3xl mb-4">com reservar?</h2>
          <div class="border rounded p-3">
            <Reserves mailto={mailTo} />
          </div>
        </div>
      </aside>
      <div class="max-w-[60rem]">
        {
          monthsWithWorkshops.map((month) => {
            return (
              <>
                <h2 class="text-2xl md:text-4xl mb-4 text-center mt-8 underline">
                  {new Date(0, month).toLocaleString('ca-ES', {
                    month: 'long',
                  })}
                </h2>
                <ul class="page-padding flex flex-wrap gap-4 py-6 overflow-hidden justify-center">
                  {formattedEventArray
                    .filter((e) => e.date.getMonth() === month)
                    .map((event) => {
                      const dateString = `${
                        weekdays[event.date.getDay()]
                      } ${event.date.toLocaleDateString('ca-ES', {
                        day: 'numeric',
                      })}`

                      const id =
                        event.tallerId +
                        event.date.toLocaleString('ca-ES', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })

                      const title =
                        event.customTitle ?? tallers[event.tallerId]?.title
                      const availability = availabilityMap[event.availability]

                      return (
                        <EventCard
                          id={id}
                          tallerId={event.tallerId}
                          title={title}
                          date={dateString}
                          time={event.time}
                          price={event.price + '€/pax'}
                          slots={availability}
                          location={event.location}
                        />
                      )
                    })}
                </ul>
              </>
            )
          })
        }

        <h2 class="text-2xl md:text-4xl mb-4 text-center mt-8">
          trobem la data adequada!
        </h2>
        <ul
          class="page-padding flex flex-wrap gap-4 py-6 overflow-hidden justify-center text-red"
        >
          <EventCard
            id="taller-a-mida"
            title="Taller a mida"
            date="Dia i hora"
            time="🌸"
            price="Preu variable"
            location="Preu i localització a convenir. Entre 4 i 16 persones. Contacta'm!"
          />
        </ul>
      </div>
    </section>
  </main>

  <hr />
  <Contact />
  <Footer />
</Layout>

<script>
  // on hash change

  const hash = decodeURI(window.location.hash).substring(1)
  const dialog = document.getElementById(hash) as HTMLDialogElement
  dialog?.showModal()
</script>

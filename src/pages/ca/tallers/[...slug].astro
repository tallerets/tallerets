---
import { getCollection } from 'astro:content'
import MonoTaller from '../../../components/screens/MonoTaller.astro'

export async function getStaticPaths() {
  const allTallers = await getCollection('mono')

  return allTallers.map(({ slug, data, body }) => {
    return {
      params: { slug },
      props: {
        title: data.title,
        desc: body,
        image: data.image,
      },
    }
  })
}

const { title, desc, image } = Astro.props
---

<MonoTaller title={title} desc={desc} image={image} />

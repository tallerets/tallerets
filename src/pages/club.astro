---
// src/pages/club.astro
// La pàgina del Club Tallerets: què és, quotes de sòcia i calendari setmanal.
// Segueix els patrons del repo: BaseLayout + Header + Footer, Tailwind amb
// els colors de tema (soft/dark/red) i valors puntuals de la paleta del
// manual de marca (Crema #F2E9B1, Argila #6F2118) com a classes arbitràries,
// per no haver de tocar el tailwind.config.
import Layout from '../layouts/BaseLayout.astro'
import Header from '../components/Header/Header.astro'
import Footer from '../components/Footer.astro'

// ── Quotes de sòcia ────────────────────────────────────────────────
// TODO Stripe: substitueix cada href pel Payment Link corresponent
// (com el que ja tens: https://buy.stripe.com/...)
const quotes = [
  {
    nom: 'Sòcia anual',
    etiqueta: 'Vine a provar',
    preu: '30€',
    periode: "l'any",
    inclou: [
      '1 dia de club per conèixer-nos',
      '5% dte. en cursos, monogràfics i botiga',
      'Festa anual de sòcies',
    ],
    href: '#', // TODO: Payment Link quota anual 30€
    destacada: false,
  },
  {
    nom: 'Sòcia Club Amiga',
    etiqueta: null,
    preu: '24€',
    periode: 'al mes',
    inclou: [
      '1 dia de club cada mes',
      '5% dte. en cursos, monogràfics i botiga',
      'Festa anual de sòcies',
    ],
    href: '#', // TODO: Payment Link subscripció 24€/mes
    destacada: false,
  },
  {
    nom: 'Sòcia Club Fem Barri',
    etiqueta: null,
    preu: '45€',
    periode: 'al mes · 22,5€/sessió',
    inclou: [
      '2 dies de club cada mes',
      '5% dte. en cursos, monogràfics i botiga',
      'Festa anual de sòcies',
    ],
    href: '#', // TODO: Payment Link subscripció 45€/mes
    destacada: false,
  },
  {
    nom: 'Sòcia Visc(a) Tallerets',
    etiqueta: 'La més completa',
    preu: '65€',
    periode: 'al mes · 16,25€/sessió',
    inclou: [
      'Club cada setmana',
      '10% dte. en cursos, monogràfics i botiga',
      'Festa anual de sòcies',
      'El millor preu per sessió',
    ],
    href: '#', // TODO: Payment Link subscripció 65€/mes
    destacada: true,
  },
]

// ── Calendari dels clubs ───────────────────────────────────────────
const setmana = [
  {
    dia: 'Dilluns',
    clubs: [
      { hora: '19:00–21:00', nom: 'Club de manualitats', tipus: 'manualitats' },
      { hora: '19:00–21:00', nom: 'Club de costura', tipus: 'costura' },
    ],
  },
  {
    dia: 'Dimarts',
    clubs: [
      { hora: '18:30–20:30', nom: 'Club de manualitats', tipus: 'manualitats' },
    ],
  },
  {
    dia: 'Dimecres',
    clubs: [
      { hora: '11:00–13:00', nom: 'Club de manualitats', tipus: 'manualitats', nou: 'Nou · matí' },
      { hora: '18:30–20:30', nom: 'Club de ganxet, brodat i punt', tipus: 'fils' },
    ],
  },
  {
    dia: 'Dijous',
    clubs: [
      { hora: '18:30–20:30', nom: 'Club de manualitats', tipus: 'manualitats' },
    ],
  },
]

const estilTipus: Record<string, string> = {
  manualitats: 'border-dark',
  costura: 'border-red',
  fils: 'border-[#6F2118] bg-[#F2E9B1] text-[#6F2118]',
}
---

<Layout
  title="Club Tallerets: fes-te sòcia del teu espai creatiu"
  description="El Club és el teu espai setmanal de creació i de barri a Sants. Fes-te sòcia des de 30€ l'any i vine a crear en comunitat."
>
  <Header className="bg-soft text-dark relative" />
  <main>
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="page-padding pt-4 text-center">
      <h1 class="text-4xl md:text-6xl md:leading-tight font-[500]">
        Club Tallerets
        <span>
          <img
            width="48"
            height="48"
            class="w-12 inline text-sm"
            src="/icons/flor.svg"
            alt=""
          />
        </span>
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg md:text-xl">
        El Club és el teu espai setmanal de creació i de barri. Vine a fer el
        teu hobbie, a provar-ne de nous que proposem o simplement a crear per
        crear. Les extraescolars per a adultxs que estaves esperant!
      </p>
    </section>

    <!-- ── Quotes de sòcia ──────────────────────────────────── -->
    <section id="quotes" class="page-padding my-8 lg:my-16">
      <h2 class="text-3xl md:text-4xl text-center md:leading-tight font-[500] mb-10">
        Tria la teva quota
        <span>
          <img
            width="40"
            height="40"
            class="w-10 inline text-sm"
            src="/icons/flor.svg"
            alt=""
          />
        </span>
      </h2>

      <ul class="mx-auto grid max-w-6xl gap-6 sm:grid-cols-2 lg:grid-cols-4 items-stretch">
        {
          quotes.map((q) => (
            <li
              class={`relative flex flex-col rounded-xl border-2 bg-white p-6 transition-all hover:-translate-y-1 ${
                q.destacada ? 'border-red shadow-lg' : 'border-dark'
              }`}
            >
              {q.etiqueta && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 -rotate-2 whitespace-nowrap bg-[#F2E9B1] px-3 py-1 font-mono text-xs uppercase tracking-wider text-[#6F2118]">
                  {q.etiqueta}
                </span>
              )}
              <h3 class="text-xl font-[500]">{q.nom}</h3>
              <p class={`mt-2 text-5xl font-[300] ${q.destacada ? 'text-red' : ''}`}>
                {q.preu}
              </p>
              <p class="mt-1 font-mono text-xs uppercase tracking-wider opacity-70">
                {q.periode}
              </p>
              <ul class="mt-4 flex-1 space-y-2 border-t-2 border-dashed border-soft pt-4 text-sm">
                {q.inclou.map((item) => (
                  <li class="flex gap-2">
                    <span class="text-red" aria-hidden="true">✿</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <a
                href={q.href}
                class={`c-button mt-6 block ${
                  q.destacada
                    ? 'border-red bg-red text-soft hover:bg-transparent'
                    : 'border-dark'
                }`}
              >
                Fes-te sòcia
              </a>
            </li>
          ))
        }
      </ul>

      <p class="mx-auto mt-8 max-w-2xl text-center text-sm opacity-80">
        Les quotes mensuals es renoven soles i, com un gimnàs, pots decidir no
        renovar fins al dia 20 de cada mes. Pagament segur amb targeta o
        domiciliació bancària.
      </p>
    </section>

    <!-- ── Calendari dels clubs ─────────────────────────────── -->
    <section id="calendari" class="page-padding my-8 lg:my-16">
      <h2 class="text-3xl md:text-4xl text-center md:leading-tight font-[500] mb-10">
        Els clubs de la setmana
        <span>
          <img
            width="40"
            height="40"
            class="w-10 inline text-sm"
            src="/icons/flor.svg"
            alt=""
          />
        </span>
      </h2>

      <div class="mx-auto grid max-w-5xl gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          setmana.map((d) => (
            <div>
              <h3 class="border-b-2 border-dark pb-2 text-center font-mono text-sm uppercase tracking-widest">
                {d.dia}
              </h3>
              <ul class="mt-3 space-y-3">
                {d.clubs.map((c) => (
                  <li
                    class={`relative rounded-xl border-2 bg-white p-4 ${estilTipus[c.tipus]}`}
                  >
                    {c.nou && (
                      <span class="absolute -top-2.5 right-3 rotate-2 bg-[#F2E9B1] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-[#6F2118]">
                        {c.nou}
                      </span>
                    )}
                    <p class="font-mono text-xs tracking-wide">{c.hora}</p>
                    <p class="mt-1 font-[500] leading-snug">{c.nom}</p>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <p class="mx-auto mt-8 max-w-2xl text-center text-sm opacity-80">
        Vine el dia que et vagi millor, segons la teva quota. Grups de màxim
        10–12 persones.
      </p>
    </section>

    <!-- ── Què és el Club ───────────────────────────────────── -->
    <section class="page-padding my-8 lg:my-16 mx-auto max-w-3xl space-y-8">
      <div>
        <h2 class="text-2xl md:text-3xl font-[500]">Què hi farem?</h2>
        <p class="mt-3">
          Pots portar aquell kit d'estampació que t'han regalat i encara no has
          estrenat. Pots venir a dibuixar, il·lustrar, pintar, fer ganxet o el
          teu hobby favorit. Pots desconnectar i gaudir de fer coses amb les
          mans i del moment present. Pots provar alguna de les mil manualitats
          que tens guardades a TikTok. Tot l'art és benvingut i no cal cap
          experiència: només ganes!
        </p>
      </div>
      <div>
        <h2 class="text-2xl md:text-3xl font-[500]">Com funciona?</h2>
        <p class="mt-3">
          Tindràs materials bàsics i eines per fer tot tipus de manualitats; si
          vols fer un projecte concret, només cal portar el material específic.
          Pots sumar-te a una activitat conjunta, venir amb el teu projecte, o
          demanar-me que t'ensenyi allò que no saps ben bé com fer. És un espai
          fora de pantalles, per fer amigues, tenir el teu lloc per crear,
          aprendre nous hobbies i inspirar-te d'altres dones creatives.
        </p>
      </div>
      <div>
        <h2 class="text-2xl md:text-3xl font-[500]">I com a sòcia, ets Tallerets</h2>
        <p class="mt-3">
          Tallerets és una associació sense ànim de lucre: fer-te sòcia vol dir
          formar part d'un projecte de barri i d'economia social. A més del
          club, tens descompte en cursos, monogràfics i botiga, la festa anual
          de sòcies, i veu al projecte.
        </p>
      </div>
      <div class="text-center">
        <p class="mb-4">
          Qualsevol dubte, escriu-me per aquí o a latallerets@gmail.com.
          T'espero al club!
        </p>
        <a href="/contacte" class="c-button inline-block border-dark">
          Contacta'm
        </a>
      </div>
    </section>
  </main>
  <hr />
  <Footer />
</Layout>

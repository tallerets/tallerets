---
import Layout from '../layouts/Layout.astro'
import Footer from '../components/sections/Footer.astro'
import Header from '../components/sections/Header.astro'
import { tallersArray, formattedEventArray } from '../content'
import TallerPostcard from '../components/TallerPostcard.astro'
import Contact from '../components/sections/Contact.astro'
import Reserves from '../components/sections/Reserves.astro'
---

<Layout title="tallerets: llista">
  <Header className="border-b bg-soft text-dark relative" />
  <main>
    <section
      class="my-4 lg:my-12 flex md:justify-center flex-wrap gap-x-16 gap-y-6"
    >
      <aside class="page-padding">
        <div class="md:w-[40rem] xl:w-80 sticky top-12 pt-4">
          <h1 class="text-2xl md:text-4xl mb-4">tots els tallerets</h1>
          <ul class="mb-8">
            {
              tallersArray.map((taller) => {
                return (
                  <li class="mb-1 list-decimal ms-4">
                    <a href={`#${taller.id}`} class="hover:underline">
                      {taller.title}
                    </a>
                  </li>
                )
              })
            }
            <li class="mb-1 list-decimal ms-4">
              <a href="#taller-a-mida" class="hover:underline">
                Tens alguna idea? Tallers a mida!
              </a>
            </li>
          </ul>
          <div class="flex mb-8">
            <a class="c-button" href="/reserva">veure calendari</a>
          </div>
          <Reserves />
        </div>
      </aside>
      <ul class="page-padding flex flex-col gap-8 py-6 overflow-hidden">
        {
          tallersArray.map((taller) => {
            const relatedEvent = formattedEventArray.find(
              (e) => e.tallerId === taller.id,
            )
            const dateString =
              relatedEvent?.date.toLocaleString('ca-ES', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              }) ?? 'Properament'
            return (
              <TallerPostcard
                id={taller.id}
                title={taller.title}
                desc={taller.desc}
                imgSrc={taller.imgSrc}
                imgAlt={taller.imgAlt}
                data={dateString}
                href={`/reserva#${relatedEvent?.tallerId}${dateString}`}
              />
            )
          })
        }
        <TallerPostcard
          id="taller-a-mida"
          title="Tens alguna idea?"
          desc="Envia’m un email a latallerets@gmail.com. Per fer-ho més fàcil, pots clicar la tarjeta del taller que vols i es copiarà al teu porta-retalls tota la informació del taller. Pots enganxar-ho al email o indicar-me en un missatge quin taller vols!"
          imgSrc="/icons/potets-gran.svg"
          imgAlt="Ilustració de dos potets amb pinzells"
          data="A convenir!"
          href="/reserva#taller-a-mida"
        />
      </ul>
    </section>
  </main>

  <hr />
  <Contact />
  <Footer />
</Layout>

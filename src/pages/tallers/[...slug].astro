---
import { getCollection } from 'astro:content'
import MonoTaller from '../../layouts/TallerLayout.astro'
import TallerLayout from '../../layouts/TallerLayout.astro'

export async function getStaticPaths() {
  const allTallers = await getCollection('mono')

  return allTallers.map((taller) => {
    const slug = taller.slug.replace('ca', '')
    return {
      params: { slug },
      props: { taller },
    }
  })
}

const { taller } = Astro.props
---

<TallerLayout taller={taller} />

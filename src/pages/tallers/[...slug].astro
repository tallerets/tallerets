---
import { getCollection } from 'astro:content'
import MonoTaller from '../../components/screens/MonoTaller.astro'

export async function getStaticPaths() {
  const allTallers = await getCollection('mono')

  return allTallers.map((taller) => {
    const slug = taller.slug.replace('ca', '')
    return {
      params: { slug },
      props: { taller },
    }
  })
}

const { taller } = Astro.props
---

<MonoTaller taller={taller} />

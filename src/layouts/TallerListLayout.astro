---
import Layout from './BaseLayout.astro'
import Footer from '../components/Footer.astro'
import Header from '../components/Header/Header.astro'
import TallerPostcard from '../components/TallerCard.astro'
import { getLangFromUrl } from '../utils'
import { getCollection, getEntry } from 'astro:content'

const lang = getLangFromUrl(Astro.url)

const monoSection = await getEntry('sections', `${lang}/partial_tallersmono`)
const cta = monoSection?.data.links?.[0]
const allTallers = await getCollection('tallers', ({ id }) => {
  return id.startsWith(lang)
})
---

<Layout
  title={monoSection?.data.title || 'Tallers'}
  description={monoSection?.data.desc || ''}
>
  <Header className="bg-soft text-dark relative" />
  <main>
    <h1
      class="pt-4 text-4xl md:text-6xl text-center md:leading-tight font-[500]"
    >
      {monoSection?.data.title}
      <span>
        <img
          width="48"
          height="48"
          class="w-12 inline text-sm"
          src="/icons/flor.svg"
          alt=""
        />
      </span>
    </h1>
    <section
      class="my-4 lg:my-12 flex md:justify-center flex-wrap gap-x-16 gap-y-4"
    >
      <aside class="page-padding">
        <div class="md:w-[40rem] xl:w-80 sticky top-12 pt-4">
          <h2 class="hidden md:block text-3xl mb-4 font-bold">
            {monoSection?.data.other.titleIndex}
          </h2>
          <ul class="mb-8 text-lg">
            {
              allTallers.map((taller) => {
                return (
                  <li class="mb-1 list-decimal ms-4">
                    <a href={`#${taller.id}`} class="hover:underline">
                      {taller.data.title}
                    </a>
                  </li>
                )
              })
            }
          </ul>
          {
            cta && (
              <div class="flex">
                <a class="c-button" href={cta.url}>
                  {cta.text}
                </a>
              </div>
            )
          }
        </div>
      </aside>
      <ul class="page-padding flex flex-col gap-10 pt-6 pb-12 overflow-hidden">
        {
          allTallers.map((taller) => {
            return <TallerPostcard taller={taller} />
          })
        }
      </ul>
    </section>
  </main>

  <hr />
  <Footer />
</Layout>

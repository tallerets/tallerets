---
import Footer from '../components/Footer.astro'

import Layout from './BaseLayout.astro'
import Header from '../components/Header/Header.astro'
import LinkList from '../components/LinkList.astro'

const { section } = Astro.props
const { Content } = await section.render()
const { title, desc, image, links } = section.data
---

<Layout title={title} description={desc}>
  <Header />
  <section class="page-padding mx-auto pt-8 pb-20 flex flex-col items-center">
    <h1
      class="text-4xl md:text-6xl text-center md:leading-tight font-[500] max-w-[20ch] mb-8 md:mb-16"
    >
      {title}
      <span>
        <img
          width="48"
          height="48"
          class="w-12 inline text-sm"
          src="/icons/flor.svg"
          alt=""
        />
      </span>
    </h1>

    <div
      class="flex flex-wrap md:flex-nowrap gap-8 md:gap-28 items-center justify-center mb-8"
    >
      {
        image.url && (
          <img
            width="320"
            height="328"
            class="w-[320px] border-8 border-dark bg-dark rounded"
            src={image.url}
            alt={image.alt}
          />
        )
      }
      <div class="text-2xl md:text-3xl max-w-[20ch] content">
        <Content />
      </div>
    </div>

    {links && <LinkList links={links} />}
  </section>

  <Footer />
</Layout>

<style>
  .content > p {
    margin-bottom: 4rem;
  }
</style>

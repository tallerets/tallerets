---
import Footer from '../components/sections/Footer.astro'
import Header from '../components/sections/Header.astro'
import BaseLayout from './BaseLayout.astro'

const { section } = Astro.props
const { Content } = await section.render()
const { title, desc, links } = section.data
---

<BaseLayout title={title} description={desc}>
  <Header />
  <section class="page-padding mx-auto pt-4 pb-12 flex flex-col items-center">
    {
      title && (
        <h1 class="text-center md:leading-tight font-[500] max-w-[20ch] mt-0">
          {title}
          <span>
            <img
              width="48"
              height="48"
              class="w-12 inline text-sm"
              src="/icons/flor.svg"
              alt=""
            />
          </span>
        </h1>
      )
    }

    <div class="text-2xl md:text-xl max-w-[50ch] content text-justify">
      <Content />
    </div>

    {
      links && (
        <div class="pb-8 pt-12 flex items-center gap-4">
          {links.map((link: { url: string; text: string }) => (
            <a
              href={link.url}
              class="block border-2 px-4 py-3 rounded-full text-2xl font-bold hover:-rotate-6 transition-transform"
            >
              {link.text}
            </a>
          ))}
        </div>
      )
    }
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  .content > p {
    margin-bottom: 1rem;
  }

  h1 {
    @apply font-bold text-4xl md:text-5xl my-8;
  }
  h2 {
    @apply font-bold text-3xl md:text-4xl my-6;
  }
  h3 {
    @apply font-bold text-2xl md:text-3xl my-6;
  }
</style>

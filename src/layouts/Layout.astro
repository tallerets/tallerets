---
import Mantainance from '../components/sections/Mantainance.astro'
import { config } from '../config'

interface Props {
  title: string
  description?: string // Maximum length 150 characters
}

const { title, description } = Astro.props
const scrollClass =
  import.meta.env.MODE !== 'development' ? 'scroll-smooth' : ''
const defaultDescription =
  'Web de tallerets. Tallers creatius per desconectar a Barcelona'
---

<!doctype html>
<html lang="ca" dir="ltr" class={`${scrollClass} bg-dark`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description ?? defaultDescription} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎨</text></svg>"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="font-serif bg-soft text-dark relative w-100 overflow-x-hidden">
    {config.maintenance ? <Mantainance /> : <slot />}
  </body>
</html>

<style is:global>
  .page-padding {
    @apply px-4 sm:px-6 md:px-8;
  }
  .c-button {
    @apply border rounded-full text-center text-xl md:text-2xl px-4 py-2 hover:-skew-y-3;
  }
  .text-border {
    --soft: #f9f9f9;
    text-shadow:
      1px 0px 0px var(--soft),
      0px 1px 0px var(--soft),
      -1px 0px 0px var(--soft),
      0px -1px 0px var(--soft);
  }
</style>

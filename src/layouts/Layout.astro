---
import Mantainance from '../components/sections/Mantainance.astro'
import Favicon from './_partials/Favicon.astro'
import { config } from '../config'

interface Props {
  title: string
  description?: string // Maximum length 150 characters
}

const { title, description } = Astro.props
const scrollClass =
  import.meta.env.MODE !== 'development' ? 'scroll-smooth' : ''
const defaultDescription =
  'Web de tallerets. Tallers creatius per desconectar a Barcelona'
---

<!doctype html>
<html lang="ca" dir="ltr" class={`${scrollClass} bg-dark`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description ?? defaultDescription} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <Favicon />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="font-serif bg-soft text-dark relative w-100 overflow-x-hidden">
    {config.maintenance ? <Mantainance /> : <slot />}
    <style is:global>
      .page-padding {
        @apply px-4 sm:px-6 md:px-8;
      }
      .c-button {
        @apply border rounded-full text-center text-xl md:text-2xl px-4 py-2 hover:-rotate-3 hover:border-red hover:text-red transition-all;
      }
      .text-border {
        --soft: #f9f9f9;
        text-shadow:
          1px 0px 0px var(--soft),
          0px 1px 0px var(--soft),
          -1px 0px 0px var(--soft),
          0px -1px 0px var(--soft);
      }
    </style>
  </body>
</html>
